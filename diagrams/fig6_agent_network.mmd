flowchart TB
    classDef default fill:#FFFFFF,stroke:#000000,stroke-width:1px,color:#000000
    
    subgraph S601["Agent Registration (Ref. 601)"]
        601a["Local shops, M-Pesa agents, kiosks in informal settlements (Ref. 601a)"]
        601b["Registered data: business name, GPS coordinates, operating hours, capacity (Ref. 601b)"]
        601a --> 601b
    end
    
    subgraph S602["Package Handoff Flow (Ref. 602)"]
        602a["Courier delivers to agent instead of final recipient (Ref. 602a)"]
        602b["Agent signature and photo captured as proof-of-delivery (Ref. 602b)"]
        602c["SMS with unique collection code sent to recipient (Ref. 602c)"]
        602d["Recipient has 48-hour collection window (Ref. 602d)"]
        602e["Recipient presents code; agent releases package (Ref. 602e)"]
        602f["Agent earns KES 30 per collected package, paid weekly via M-Pesa (Ref. 602f)"]
        
        602a --> 602b
        602b --> 602c
        602c --> 602d
        602d --> 602e
        602e --> 602f
    end
    
    601b -.-> 602a
    
    linkStyle default stroke:#000000,stroke-width:1px
